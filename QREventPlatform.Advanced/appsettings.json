{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER,1433;Database=QREventDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;Trusted_Connection=False;TrustServerCertificate=True"
  },

  "Jwt": {
    "Issuer": "QREventPlatform",
    "Audience": "QREventPlatformUsers",
    "Key": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY",
    "ExpiryMinutes": 1440
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUser": "YOUR_SMTP_USER",
    "SmtpPass": "YOUR_SMTP_PASSWORD",
    "DisableCertCheck": false
  },
  "AllowedHosts": "*"
}
